{
  "name": "DWFA Blue",
  "dataColors": [
    "#2F9AD6",
    "#1F5F8B",
    "#5FB7E5",
    "#163A59",
    "#8CCCED",
    "#6E8597"
  ],
  "background": "#F7FBFE",
  "foreground": "#243746",
  "tableAccent": "#2F9AD6",
  "good": "#2F9AD6",
  "neutral": "#6E8597",
  "bad": "#163A59",
  "maximum": "#163A59",
  "center": "#5FB7E5",
  "minimum": "#EAF6FD",
  "visualStyles": {
    "*": {
      "*": {
        "title": [
          {
            "show": true,
            "color": { "solid": { "color": "#163A59" } },
            "fontSize": 13,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "labels": [
          {
            "color": { "solid": { "color": "#243746" } },
            "fontSize": 11,
            "fontFamily": "Segoe UI"
          }
        ],
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#EAF6FD" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#D6EDF9" } },
            "radius": 6
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": { "solid": { "color": "#6E8597" } },
            "fontSize": 11,
            "fontFamily": "Segoe UI"
          }
        ],
        "categoryLabels": [
          {
            "color": { "solid": { "color": "#6E8597" } },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ],
        "calloutValue": [
          {
            "color": { "solid": { "color": "#163A59" } },
            "fontSize": 24,
            "fontFamily": "Segoe UI Semibold"
          }
        ]
      }
    },
    "tableEx": {
      "*": {
        "grid": [
          {
            "gridVertical": true,
            "gridHorizontal": true,
            "outlineColor": { "solid": { "color": "#D6EDF9" } },
            "fontColor": { "solid": { "color": "#243746" } }
          }
        ]
      }
    },
    "matrix": {
      "*": {
        "grid": [
          {
            "gridVertical": true,
            "gridHorizontal": true,
            "outlineColor": { "solid": { "color": "#D6EDF9" } },
            "fontColor": { "solid": { "color": "#243746" } }
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "items": [
          {
            "fontColor": { "solid": { "color": "#243746" } },
            "textSize": 11,
            "fontFamily": "Segoe UI"
          }
        ],
        "title": [
          {
            "show": true,
            "color": { "solid": { "color": "#163A59" } }
          }
        ]
      }
    }
  }
}
